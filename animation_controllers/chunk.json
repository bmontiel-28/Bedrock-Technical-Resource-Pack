{
  "format_version" : "1.10.0",
  "animation_controllers" : {
    "controller.animation.chunk_control" : {
      "initial_state" : "default",
      "states" : {
        "default" : {
          "transitions" : [
            { "show" : "query.is_local_player && !query.is_in_ui && query.is_item_name_any('slot.weapon.offhand', 0, 'minecraft:firework_rocket')" }
          ]
        },
        "show" : {
          "animations": [ "chunk" ],
          "transitions" : [
            { "default" : "!query.is_item_name_any('slot.weapon.offhand', 0, 'minecraft:firework_rocket')" }
          ]
        }
      }
    }
  }
}
