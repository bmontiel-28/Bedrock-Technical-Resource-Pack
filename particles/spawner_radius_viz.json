{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "addon:spawner_radius_viz",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/spawner_radius"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },
      "minecraft:emitter_lifetime_once": {},
      "minecraft:emitter_shape_point": {
        "offset": [0, 0, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "expiration_expression": "return !query.is_item_name_any('slot.weapon.offhand', 0, 'minecraft:nautilus_shell');",
        "max_lifetime": 86400
      },
      "minecraft:particle_motion_parametric": {
        "relative_position": [
          "query.position(0) + v.re_pos_x",
          "query.position(1) + v.re_pos_y",
          "query.position(2) + v.re_pos_z"
        ],
        "direction": ["v.dir_x", "v.dir_y", "v.dir_z"]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [128, "v.face == 0 ? 128 : 80"],
        "facing_camera_mode": "direction_z",
        "uv": {
          "texture_width": 1,
          "texture_height": 5,
          "uv": [0, "v.face"],
          "uv_size": [1, 1]
        }
      }
    }
  }
}
